@page "/tickets"
@using System.Collections
@inject HttpClient Http

@rendermode InteractiveServer
@attribute [Authorize]

<PageTitle>Tickets</PageTitle>

@* Container principale *@
<div class="tickets-container">
    
    @* Header con titolo e bottone *@
    <div class="page-header">
        <h3>Gestione Tickets</h3>
        <button class="fetch-button" @onclick="@OnInitializedAsync">
            <span>📋</span> Ricarica Tickets
        </button>
        <button class="fetch-button" @onclick="@send">
            <span>✅</span> Salva Tutte le modifiche
        </button>
        <button class="fetch-button" @onclick="@NewTicket">
            <span>➕</span> Aggiungi Ticket
        </button>
    </div>

    @* Tabella tickets *@
    <div class="table-container">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>ID Ticket</th>
                    <th>Azienda Cliente</th>
                    <th>Cliente</th>
                    <th>Oggetto</th>
                    <th>Stato</th>
                    <th>Priorità</th>
                    <th>Assegnato a</th>
                    <th>Aperto il</th>
                </tr>
            </thead>
            <tbody>
                @if (Tick == null || !Tick.Any())
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                @if (isLoading)
                                {
                                    <div class="loading-state">
                                        <div class="loading-spinner"></div>
                                        <span>Caricamento tickets...</span>
                                    </div>
                                }
                                else
                                {
                                    <span>Nessun ticket disponibile. Clicca "Carica Tickets" per visualizzarli.</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var ticket in Tick)
                    {
                        <tr>
                            <td>@ticket.Id</td>
                            <td>@ticket.DatiCliente</td>
                            <td>@ticket.Richiedente</td>
                            <td>@ticket.DescrizioneDettagliata</td>
                            <td>
                                <span class="status-badge @GetStatusClass(ticket.Categoria)">
                                    @ticket.Categoria
                                </span>
                            </td>
                            <td>
                                <span class="priority-badge @GetPriorityClass(ticket.Urgenza)">
                                    @ticket.Urgenza
                                </span>
                            </td>
                            <td>@ticket.Assegnatario</td>
                            <td>@ticket.DataCreazione</td>
                            <td><button class="btn btn-primary btn-sm" @onclick="()=>ModificaTicket(ticket)">Modifica</button></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        @if (editingTicket != null)
        {
            <div class="modal-overlay">
                <div class="modal-box">
                
                    <h4>Modifica Ticket @editingTicket.Id</h4>

                    <EditForm Model="editingTicket">

                        <div class="form-group">
                            <label>Dati Cliente</label>
                            <InputText @bind-Value="editingTicket.DatiCliente" />
                        </div>

                        <div class="form-group">
                            <label>Richiedente</label>
                            <InputText @bind-Value="editingTicket.Richiedente" />
                        </div>

                        <div class="form-group">
                            <label>Descrizione</label>
                            <InputTextArea @bind-Value="editingTicket.DescrizioneDettagliata" class="textarea-big" />
                        </div>

                        <div class="form-group">
                            <label>Categoria</label>
                            <InputSelect @bind-Value="editingTicket.Categoria">
                                <option value="Aperto">Aperto</option>
                                <option value="In lavorazione">In lavorazione</option>
                                <option value="Chiuso">Chiuso</option>
                            </InputSelect>
                        </div>

                        <div class="form-group">
                            <label>Urgenza</label>
                            <InputSelect @bind-Value="editingTicket.Urgenza">
                                <option value="Alta">Alta</option>
                                <option value="Media">Media</option>
                                <option value="Bassa">Bassa</option>
                            </InputSelect>
                        </div>

                        <div class="form-group">
                            <label>Assegnatario</label>
                            <InputText @bind-Value="editingTicket.Assegnatario" />
                        </div>

                        <div class="modal-actions">
                            <button type="button" @onclick="() => SaveSingleTicket(editingTicket.Id)">
                                Salva
                            </button>

                            <button type="button" class="btn-cancel" @onclick="Annulla">
                                Annulla
                            </button>
                        </div>

                    </EditForm>

                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool isLoading = false;
    List<Ticket>? Tick = new List<Ticket>();
    List<Ticket>? TickToSave = new List<Ticket>();
    
    

    Ticket? editingTicket;
    
    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try 
        {
            Tick = await Http.GetFromJsonAsync<List<Ticket>>("/api/tickets");
            //await Task.Delay(1000);
            
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private string GetStatusClass(string status)
    {
        return status?.ToLower() switch
        {
            "aperto" => "open",
            "in lavorazione" => "in-progress",
            "chiuso" => "closed",
            _ => ""
        };
    }
    
    private string GetPriorityClass(string priority)
    {
        return priority?.ToLower() switch
        {
            "alta" => "high",
            "media" => "medium",
            "bassa" => "low",
            _ => ""
        };
    }

    private async Task send(){
        if(TickToSave!.Count > 0){
            await Http.PostAsJsonAsync("/api/savetickets", TickToSave);
            TickToSave = new List<Ticket>();
        }else {
            Console.WriteLine("non c'è stata alcuna modifica nei tickets");
        }
    }

    private void ModificaTicket(Ticket ticket)
    {
        editingTicket = new Ticket(

            ticket.Id,
            ticket.Assegnatario,
            ticket.Categoria,
            ticket.DatiCliente,
            ticket.DescrizioneDettagliata,
            ticket.Richiedente,
            ticket.Urgenza,
            ticket.DataCreazione
        );
    }
    private void Annulla(){
        editingTicket = null;
    }

    private void SaveSingleTicket(int id){
        var t = new Ticket(
                    editingTicket!.Id,
                    editingTicket.Assegnatario,
                    editingTicket.Categoria,
                    editingTicket.DatiCliente,
                    editingTicket.DescrizioneDettagliata,
                    editingTicket.Richiedente,
                    editingTicket.Urgenza,
                    editingTicket.DataCreazione
                );
        for(int i = 0; i< Tick!.Count; i++){
            if(Tick[i].Id == id){
                Tick[i] = t;
                if(TickToSave!.Count>0){
                    for(int j = 0; j< TickToSave!.Count; j++){
                        if(TickToSave[j].Id == Tick[i].Id){
                            TickToSave[j] = Tick[i];
                            editingTicket = null;
                            return;
                        }
                    }
                }
                TickToSave!.Add(Tick[i]);
                editingTicket = null;
                return;
            }
        }

        TickToSave!.Add(t);
        editingTicket = null;
        return;
    }

    private void NewTicket(){
        editingTicket = new Ticket(

            Tick!.Count+1,
            "",
            "",
            "",
            "",
            "",
            "",
            DateTime.UtcNow
        );
    }


}
